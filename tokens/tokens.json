{
  "$schema": "https://json.schemastore.org/design-tokens",
  "meta": {
    "repo": "https://github.com/Plura-AI/blacklist-design-system",
    "version": "1.0.0",
    "brand": "The Blacklist Alliance",
    "description": "Machine-readable design tokens. All values match the CSS custom properties in colors_and_type.css. This file is the source of truth for non-CSS consumers (React Native, Figma plugins, Tailwind config, design tooling)."
  },
  "color": {
    "brand": {
      "red":        { "value": "#A50100", "comment": "Primary brand red — CTAs, logo mark, risk bar, critical states. Cap at ~10% of any view." },
      "red-hover":  { "value": "#8A0100", "comment": "Hover state for red interactive elements." },
      "red-press":  { "value": "#6E0100", "comment": "Active/press state for red interactive elements." },
      "red-tint":   { "value": "#FBE5E5", "comment": "Very light red wash — use for error/danger backgrounds only." },
      "black":      { "value": "#000000", "comment": "Primary dark surface and text." },
      "white":      { "value": "#FFFFFF", "comment": "Primary light surface and inverse text." }
    },
    "gray": {
      "00":  { "value": "#FFFFFF" },
      "05":  { "value": "#F7F7F7" },
      "10":  { "value": "#EFEFEF" },
      "20":  { "value": "#E0E0E0" },
      "30":  { "value": "#C9C9C9" },
      "40":  { "value": "#A8A8A8" },
      "50":  { "value": "#8C8C8C" },
      "60":  { "value": "#6F6F6F" },
      "70":  { "value": "#525252" },
      "80":  { "value": "#393939" },
      "90":  { "value": "#1F1F1F" },
      "100": { "value": "#000000" }
    },
    "semantic": {
      "success":     { "value": "#117A3D" },
      "success-bg":  { "value": "#E5F4EC" },
      "warning":     { "value": "#B36B00" },
      "warning-bg":  { "value": "#FFF3DD" },
      "danger":      { "value": "#A50100", "comment": "Same as brand red — intentional. Compliance product: red means stop." },
      "danger-bg":   { "value": "#FBE5E5" },
      "info":        { "value": "#0F4C8A" },
      "info-bg":     { "value": "#E5EEF7" }
    },
    "surface": {
      "canvas":  { "value": "#F7F7F7", "comment": "Page background (gray-05)." },
      "panel":   { "value": "#FFFFFF", "comment": "Cards and panels (gray-00)." },
      "sunken":  { "value": "#EFEFEF", "comment": "Inputs and code blocks (gray-10)." },
      "inverse": { "value": "#000000", "comment": "Dark hero/footer sections (bl-black)." }
    },
    "foreground": {
      "primary":     { "value": "#000000", "comment": "gray-100 — primary body text." },
      "secondary":   { "value": "#525252", "comment": "gray-70 — secondary text." },
      "tertiary":    { "value": "#8C8C8C", "comment": "gray-50 — meta text." },
      "placeholder": { "value": "#A8A8A8", "comment": "gray-40 — disabled / placeholder." },
      "on-red":      { "value": "#FFFFFF" },
      "on-black":    { "value": "#FFFFFF" }
    },
    "border": {
      "default": { "value": "#E0E0E0", "comment": "gray-20 — 1px hairline." },
      "hover":   { "value": "#C9C9C9", "comment": "gray-30 — hover / stronger." },
      "on-dark": { "value": "#393939", "comment": "gray-80 — on dark backgrounds." }
    }
  },
  "typography": {
    "family": {
      "sans": { "value": "\"General Sans\", ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif", "comment": "The only typeface. Never substitute another display or body font." },
      "mono": { "value": "ui-monospace, SFMono-Regular, Menlo, Consolas, \"Liberation Mono\", monospace", "comment": "System monospace stack — used for code blocks and tabular data only." }
    },
    "weight": {
      "extralight": { "value": 200 },
      "light":      { "value": 300 },
      "regular":    { "value": 400 },
      "medium":     { "value": 500 },
      "semibold":   { "value": 600 },
      "bold":       { "value": 700, "comment": "Headlines and taglines. The primary headline weight." }
    },
    "size": {
      "12": { "value": "0.75rem",  "px": 12,  "use": "Micro labels, captions, meta" },
      "14": { "value": "0.875rem", "px": 14,  "use": "Body small, secondary meta" },
      "16": { "value": "1rem",     "px": 16,  "use": "Body default" },
      "18": { "value": "1.125rem", "px": 18,  "use": "Body large / lede" },
      "20": { "value": "1.25rem",  "px": 20,  "use": "H6" },
      "24": { "value": "1.5rem",   "px": 24,  "use": "H5" },
      "28": { "value": "1.75rem",  "px": 28,  "use": "H4" },
      "32": { "value": "2rem",     "px": 32,  "use": "H3" },
      "40": { "value": "2.5rem",   "px": 40,  "use": "H2" },
      "56": { "value": "3.5rem",   "px": 56,  "use": "H1" },
      "72": { "value": "4.5rem",   "px": 72,  "use": "Display" },
      "96": { "value": "6rem",     "px": 96,  "use": "Hero display" }
    },
    "lineHeight": {
      "tight": { "value": 0.95 },
      "snug":  { "value": 1.1 },
      "base":  { "value": 1.5 },
      "loose": { "value": 1.7 }
    },
    "letterSpacing": {
      "tight":  { "value": "-0.02em", "use": "Display and big headlines" },
      "snug":   { "value": "-0.01em", "use": "H2 / H3" },
      "base":   { "value": "0em" },
      "wide":   { "value": "0.06em",  "use": "Eyebrows, ALL CAPS labels" },
      "wider":  { "value": "0.12em",  "use": "Tight caps / nav items" }
    },
    "patterns": {
      "tagline": {
        "transform": "lowercase",
        "weight": 700,
        "letterSpacing": "-0.03em",
        "lineHeight": 0.92,
        "comment": "The signature brand pattern — e.g. 'risk less. connect more.' Always paired with a .ds-subhead below it."
      },
      "subhead": {
        "transform": "uppercase",
        "weight": 500,
        "letterSpacing": "0.06em",
        "comment": "The UPPERCASE Medium subhead placed under the tagline."
      },
      "eyebrow": {
        "transform": "uppercase",
        "weight": 600,
        "size": 14,
        "letterSpacing": "0.12em",
        "comment": "Section labels, nav items, pill labels."
      },
      "button": {
        "weight": 600,
        "transform": "uppercase",
        "letterSpacing": "0.06em",
        "comment": "ALL CAPS, semibold. e.g. BOOK A FREE DEMO"
      }
    }
  },
  "spacing": {
    "base": { "value": 4, "unit": "px", "comment": "4px base unit. All spacing is a multiple of 4." },
    "0":  { "value": "0" },
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "7":  { "value": "32px" },
    "8":  { "value": "40px" },
    "9":  { "value": "48px" },
    "10": { "value": "64px" },
    "11": { "value": "80px" },
    "12": { "value": "96px" },
    "13": { "value": "128px" },
    "14": { "value": "160px" }
  },
  "radius": {
    "comment": "Zero everywhere. Square corners are the brand. All tokens resolve to 0px — they exist only so code can express intent ('this is a pill') while remaining visually square.",
    "0":    { "value": "0px" },
    "1":    { "value": "0px" },
    "2":    { "value": "0px" },
    "3":    { "value": "0px" },
    "4":    { "value": "0px" },
    "pill": { "value": "0px" }
  },
  "shadow": {
    "0":     { "value": "none",                                                                    "use": "Flat, no elevation" },
    "1":     { "value": "0 1px 2px rgba(0,0,0,0.06), 0 1px 1px rgba(0,0,0,0.04)",               "use": "Cards, default surfaces" },
    "2":     { "value": "0 4px 12px rgba(0,0,0,0.08), 0 1px 2px rgba(0,0,0,0.04)",              "use": "Elevated cards" },
    "3":     { "value": "0 12px 32px rgba(0,0,0,0.12), 0 2px 4px rgba(0,0,0,0.06)",             "use": "Dropdowns, menus" },
    "4":     { "value": "0 24px 60px rgba(0,0,0,0.18)",                                          "use": "Modals, popovers" },
    "focus": { "value": "0 0 0 3px rgba(165, 1, 0, 0.28)",                                       "use": "3px red glow — always use instead of browser default outline" }
  },
  "motion": {
    "easing": {
      "out":    { "value": "cubic-bezier(0.2, 0.7, 0.2, 1)",  "use": "Default reactive transitions" },
      "in":     { "value": "cubic-bezier(0.5, 0, 0.75, 0)",   "use": "Exit transitions" },
      "in-out": { "value": "cubic-bezier(0.65, 0, 0.35, 1)",  "use": "Hover swaps, theme changes" }
    },
    "duration": {
      "1": { "value": "120ms", "use": "Micro interactions — icon swaps, color shifts" },
      "2": { "value": "180ms", "use": "Button hover, link underline" },
      "3": { "value": "280ms", "use": "Panel reveal, dropdown open" },
      "4": { "value": "480ms", "use": "Hero entrances only" }
    }
  },
  "layout": {
    "container": {
      "sm": { "value": "640px" },
      "md": { "value": "960px" },
      "lg": { "value": "1200px",  "use": "Default content max-width" },
      "xl": { "value": "1440px",  "use": "Marketing pages" }
    },
    "grid": {
      "columns": { "value": 12 },
      "gutter":  { "value": "24px" }
    }
  },
  "brand": {
    "riskBar": {
      "width":  { "value": "56px" },
      "height": { "value": "4px" },
      "color":  { "value": "#A50100" },
      "comment": "The brand signature accent rule. Solid red, placed above section headlines. Use sparingly — max once per major section."
    },
    "icons": {
      "set":        { "value": "Lucide" },
      "size":       { "value": "24px",  "app": "20px" },
      "stroke":     { "value": "2px" },
      "color":      { "value": "currentColor" },
      "cdn":        { "value": "https://unpkg.com/lucide@latest" },
      "comment": "Never fill icons. Never use emoji as icons. Never use a different icon set."
    },
    "logo": {
      "on-white": { "value": "assets/blacklist-logo-on-white.svg" },
      "on-black": { "value": "assets/blacklist-logo-on-black.svg" },
      "favicon":  { "value": "assets/blacklist-favicon.svg" },
      "comment": "Use SVGs verbatim. Never recreate the wordmark with text. Red in SVG files is #B5001F (as supplied); system spec is #A50100."
    }
  }
}
